<%
  var p = typeof print !== 'undefined' ? print : {};
  var vias = [
    { label: 'Gerente', slug: 'gerente', sig1: 'Visto — Gerência', sig2: 'Data' },
    { label: 'Cliente', slug: 'cliente', sig1: 'Assinatura do cliente', sig2: 'Data' },
  ];
  function esc(v) {
    var s = (v || '').toString();
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
  }
%>
<div class="os-print-area">
  <% vias.forEach(function (via, idx) { %>
  <% if (idx > 0) { %><hr class="os-cut-line" aria-hidden="true" /><% } %>
  <div class="os-via">
    <div class="os-via-label os-via-label--<%= via.slug %>"><%= esc(via.label) %></div>
    <div class="os-header">
      <div class="os-header-logo">
        <img src="/img/logocleany.png" alt="Cleany" />
      </div>
      <div class="os-header-info">
        <div class="os-header-empresa">Cleany — Trituradores de Resíduos</div>
        <div class="os-header-sub">Ordem de Serviço</div>
        <% if (p.emittedAt) { %>
        <div class="os-emitted">Emitida em <%= esc(p.emittedAt) %></div>
        <% } %>
      </div>
      <div class="os-header-num">
        <div class="os-header-num-label">Nº O.S.</div>
        <div class="os-header-num-big"><%= esc(p.id) %></div>
        <div class="os-header-status"><%= esc(p.status) %></div>
      </div>
    </div>

    <div class="os-section">
      <div class="os-section-title">Dados do cliente</div>
      <div class="os-client-grid">
        <div class="os-field--span2">
          <div class="os-field-label">Nome / Razão social</div>
          <div class="os-field-value os-field-value--name"><%= esc(p.customer_name) %></div>
          <% if (p.nome_fantasia) { %>
          <div class="os-field-value os-field-value--fantasia">Nome fantasia: <%= esc(p.nome_fantasia) %></div>
          <% } %>
        </div>
        <div>
          <div class="os-field-label">Código</div>
          <div class="os-field-value"><%= esc(p.customer_codigo || '—') %></div>
        </div>
        <div>
          <div class="os-field-label">CPF / CNPJ</div>
          <div class="os-field-value"><%= esc(p.document || '—') %></div>
        </div>
        <div>
          <div class="os-field-label">Telefone</div>
          <div class="os-field-value"><%= esc(p.phone || '—') %></div>
        </div>
        <div>
          <div class="os-field-label">E-mail</div>
          <div class="os-field-value"><%= esc(p.email || '—') %></div>
        </div>
      </div>
      <div class="os-address-box">
        <div class="os-field-label">Endereço completo</div>
        <% if (p.address_lines && p.address_lines.length) { %>
          <% p.address_lines.forEach(function (line) { %>
          <div class="os-address-line"><%= esc(line) %></div>
          <% }); %>
        <% } else { %>
          <div class="os-address-line"><%= esc(p.address_full || '—') %></div>
        <% } %>
      </div>
    </div>

    <div class="os-section">
      <div class="os-section-title">Serviço</div>
      <div class="os-service-row">
        <div>
          <div class="os-field-label">Data / hora prevista</div>
          <div class="os-field-value"><%= esc(p.dataPrev || '—') %></div>
        </div>
        <div>
          <div class="os-field-label">Valor estimado</div>
          <div class="os-field-value"><%= esc(p.valEst || '—') %></div>
        </div>
        <div>
          <div class="os-field-label">Valor final</div>
          <div class="os-field-value"><%= esc(p.valFin || '—') %></div>
        </div>
      </div>
      <div class="os-field-label" style="margin-top:1mm">Descrição</div>
      <div class="os-desc"><%= esc(p.description || '—') %></div>
    </div>

    <div class="os-signatures">
      <div class="os-sig-block"><div class="os-sig-line"><%= esc(via.sig1) %></div></div>
      <div class="os-sig-block"><div class="os-sig-line"><%= esc(via.sig2) %></div></div>
    </div>
  </div>
  <% }); %>
</div>
