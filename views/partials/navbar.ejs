    </button>
  </div>
  <nav class="sidebar-nav" id="sidebar-nav">
    <a href="/" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span>
      Página inicial
    </a>
    <a href="/clientes" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
      Clientes
    </a>
    <a href="/calendario" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></span>
      Calendário
    </a>
    <a href="/ordens" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg></span>
      Gerar O.S.
    </a>
    <a href="/servicos" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg></span>
      Serviços
    </a>
    <a href="/financeiro" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></span>
      Financeiro
    </a>
    <a href="/historico-agendamentos" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span>
      Histórico de agendamentos
    </a>
    <% if (typeof canManageUsers !== 'undefined' && canManageUsers) { %>
    <a href="/admin/usuarios" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
      Usuários do sistema
    </a>
    <a href="/admin/sistema" class="sidebar-link">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg></span>
      Manutenção
    </a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <a href="/logout" class="sidebar-link" id="sidebar-logout" data-logout-url="/logout">
      <span class="sidebar-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span>
      Sair
    </a>
  </div>
</aside>

<div id="confirm-action-modal" class="logout-modal confirm-action-modal" aria-hidden="true">
  <div class="logout-modal-backdrop confirm-action-backdrop"></div>
  <div class="logout-modal-dialog">
    <div class="logout-modal-icon confirm-action-icon" style="color: var(--primary-green);">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    </div>
    <h3 class="logout-modal-title confirm-action-title">Confirmar</h3>
    <p class="logout-modal-text confirm-action-text">Deseja realmente continuar?</p>
    <div class="logout-modal-actions">
      <button type="button" class="btn btn-secondary confirm-action-cancel">Cancelar</button>
      <button type="button" class="btn btn-primary confirm-action-confirm">Sim, confirmar</button>
    </div>
  </div>
</div>

<div id="logout-modal" class="logout-modal" aria-hidden="true">
  <div class="logout-modal-backdrop"></div>
  <div class="logout-modal-dialog">
    <div class="logout-modal-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </div>
    <h3 class="logout-modal-title">Sair?</h3>
    <p class="logout-modal-text">Deseja realmente encerrar sua sessão?</p>
    <div class="logout-modal-actions">
      <button type="button" class="btn btn-secondary" id="logout-modal-cancel">Cancelar</button>
      <a href="/logout" class="btn btn-primary" id="logout-modal-confirm">Sim, sair</a>
    </div>
  </div>
</div>

<script>
(function() {
  var modal = document.getElementById('logout-modal');
  var trigger = document.getElementById('sidebar-logout');
  var cancelBtn = document.getElementById('logout-modal-cancel');
  var confirmLink = document.getElementById('logout-modal-confirm');
  if (!modal || !trigger) return;
  trigger.addEventListener('click', function(e) {
    e.preventDefault();
    modal.classList.add('logout-modal--open');
    modal.setAttribute('aria-hidden', 'false');
  });
  function closeModal() {
    modal.classList.remove('logout-modal--open');
    modal.setAttribute('aria-hidden', 'true');
  }
  if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
  if (modal.querySelector('.logout-modal-backdrop')) {
    modal.querySelector('.logout-modal-backdrop').addEventListener('click', closeModal);
  }
  if (confirmLink) confirmLink.setAttribute('href', trigger.getAttribute('data-logout-url') || '/logout');
})();

(function() {
  var modal = document.getElementById('confirm-action-modal');
  if (!modal) return;
  var titleEl = modal.querySelector('.confirm-action-title');
  var textEl = modal.querySelector('.confirm-action-text');
  var cancelBtn = modal.querySelector('.confirm-action-cancel');
  var confirmBtn = modal.querySelector('.confirm-action-confirm');
  var backdrop = modal.querySelector('.confirm-action-backdrop');
  var formToSubmit = null;

  function openConfirm(title, text, onSubmit) {
    if (titleEl) titleEl.textContent = title || 'Confirmar';
    if (textEl) textEl.textContent = text || 'Deseja continuar?';
    formToSubmit = onSubmit;
    modal.classList.add('logout-modal--open');
    modal.setAttribute('aria-hidden', 'false');
  }

  function closeConfirm() {
    modal.classList.remove('logout-modal--open');
    modal.setAttribute('aria-hidden', 'true');
    formToSubmit = null;
  }

  if (confirmBtn) {
    confirmBtn.addEventListener('click', function() {
      if (formToSubmit && typeof formToSubmit === 'object' && formToSubmit.submit) {
        formToSubmit.submit();
      } else if (typeof formToSubmit === 'function') {
        formToSubmit();
      }
      closeConfirm();
    });
  }
  if (cancelBtn) cancelBtn.addEventListener('click', closeConfirm);
  if (backdrop) backdrop.addEventListener('click', closeConfirm);

  document.addEventListener('submit', function(e) {
    var form = e.target;
    if (!form || !form.classList.contains('js-confirm-submit')) return;
    var ifStatus = form.getAttribute('data-confirm-if-status');
    var ifValue = form.getAttribute('data-confirm-if-value');
    if (ifStatus && ifValue) {
      var select = form.querySelector('[name="' + ifStatus + '"]');
      if (!select || select.value !== ifValue) return;
    }
    e.preventDefault();
    var title = form.getAttribute('data-confirm-title') || 'Confirmar';
    var msg = form.getAttribute('data-confirm-msg') || 'Deseja realmente continuar?';
    openConfirm(title, msg, form);
  }, true);
})();

(function() {
  var toggle = document.getElementById('sidebar-toggle');
  var closeBtn = document.getElementById('sidebar-close');
  var sidebar = document.getElementById('sidebar-nav-drawer');
  var overlay = document.getElementById('sidebar-overlay');
  if (!sidebar || !overlay) return;

  function closeNav() {
    sidebar.classList.remove('sidebar--open');
    overlay.classList.remove('sidebar-overlay--visible');
    overlay.setAttribute('aria-hidden', 'true');
    if (toggle) toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  function openNav() {
    sidebar.classList.add('sidebar--open');
    overlay.classList.add('sidebar-overlay--visible');
    overlay.setAttribute('aria-hidden', 'false');
    if (toggle) toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  if (toggle) {
    toggle.addEventListener('click', function() {
      if (sidebar.classList.contains('sidebar--open')) closeNav();
      else openNav();
    });
  }
  if (closeBtn) closeBtn.addEventListener('click', closeNav);
  overlay.addEventListener('click', closeNav);
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeNav();
  });

  sidebar.querySelectorAll('a.sidebar-link').forEach(function(link) {
    link.addEventListener('click', function() {
      closeNav();
    });
  });

  window.addEventListener('resize', function() {
    if (!document.documentElement.classList.contains('layout-compact')) closeNav();
  });
})();
</script>

