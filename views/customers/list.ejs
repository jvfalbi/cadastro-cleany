<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Clientes - Cleany</title>
    <%- include('../partials/head-viewport') %>
    <%- include('../partials/head-styles') %>
  </head>
  <body>
    <div class="app-shell">
      <div class="layout layout--nav-drawer">
        <%- include('../partials/navbar') %>
        <main class="main-content">
          <div class="container">
            <div class="page-header">
              <div>
                <div class="page-title">Clientes cadastrados</div>
                <div class="page-subtitle">
                  Gerencie rapidamente os clientes da Cleany.
                </div>
              </div>
              <a href="/clientes/novo" class="btn btn-primary">+ Novo cliente</a>
            </div>

            <div class="card">
              <% function esc(v) {
  var s = (v || '').toString().replace(/\0/g,'').replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '');
  return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
} %>
              <% if (customers && customers.length) { %>
              <p id="clientes-filter-no-match" class="clientes-filter-no-match" hidden role="status">
                Nenhum cliente corresponde aos filtros (a lista não foi apagada). Use <strong>Limpar</strong> ou esvazie os campos de pesquisa.
              </p>
              <% } %>
              <table class="table-clientes">
                <colgroup>
                  <col style="width: 7rem" />
                  <col style="width: 18%" />
                  <col style="width: 11%" />
                  <col style="width: 14%" />
                  <col />
                  <col style="width: 10rem" />
                </colgroup>
                <thead>
                  <tr class="filter-row">
                    <th>
                      <button type="button" class="th-sort" data-sort-col="codigo" aria-label="Ordenar por código">
                        <span class="th-sort-text">Código</span><span class="th-sort-dir" aria-hidden="true"></span>
                      </button>
                      <input type="search" id="filter-codigo" name="search_codigo" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por código" autocomplete="off" autocorrect="off" spellcheck="false" />
                    </th>
                    <th>
                      <button type="button" class="th-sort" data-sort-col="nome" aria-label="Ordenar por nome">
                        <span class="th-sort-text">Nome</span><span class="th-sort-dir" aria-hidden="true"></span>
                      </button>
                      <input type="search" id="filter-nome" name="search_nome" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por nome" autocomplete="off" autocorrect="off" spellcheck="false" />
                    </th>
                    <th>
                      <button type="button" class="th-sort" data-sort-col="cpf" aria-label="Ordenar por CPF">
                        <span class="th-sort-text">CPF</span><span class="th-sort-dir" aria-hidden="true"></span>
                      </button>
                      <input type="search" id="filter-cpf" name="search_cpf" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por CPF" autocomplete="off" autocorrect="off" spellcheck="false" />
                    </th>
                    <th>
                      <button type="button" class="th-sort" data-sort-col="celular" aria-label="Ordenar por celular">
                        <span class="th-sort-text">Celular</span><span class="th-sort-dir" aria-hidden="true"></span>
                      </button>
                      <input type="search" id="filter-celular" name="search_celular" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por celular" autocomplete="off" autocorrect="off" spellcheck="false" />
                    </th>
                    <th>
                      <button type="button" class="th-sort" data-sort-col="endereco" aria-label="Ordenar por endereço">
                        <span class="th-sort-text">Endereço</span><span class="th-sort-dir" aria-hidden="true"></span>
                      </button>
                      <input type="search" id="filter-endereco" name="search_endereco" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por endereço" autocomplete="off" autocorrect="off" spellcheck="false" />
                    </th>
                    <th class="filter-actions">
                      <span class="th-label">Ações</span>
                      <button type="button" class="btn btn-secondary btn-sm" id="filter-clear" title="Limpar filtros">Limpar</button>
                    </th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!customers || customers.length === 0) { %>
                  <tr class="filterable-row">
                    <td colspan="6" class="table-empty">
                      Nenhum cliente cadastrado ainda. Clique em "Novo cliente"
                      para começar.
                    </td>
                  </tr>
                  <% } else { %> <% customers.forEach(function (c) { %>
                  <% var _codDigits = String(c.codigo || '').replace(/\D/g, ''); var _sortCod = _codDigits === '' ? -1 : parseInt(_codDigits, 10); %>
                  <tr class="filterable-row" data-row-id="<%= c.id %>" data-sort-codigo-num="<%= isNaN(_sortCod) ? -1 : _sortCod %>" data-codigo="<%= esc((c.codigo || '').toLowerCase()) %>" data-nome="<%= esc((c.name || '').toLowerCase()) %>" data-cpf="<%= esc((c.document || '').toLowerCase()) %>" data-celular="<%= esc((c.phone || '').toLowerCase()) %>" data-endereco="<%= esc((c.address_display || c.address || '').toLowerCase()) %>">
                    <td><%= esc(c.codigo || '-') %></td>
                    <td><%= esc(c.name || '') %></td>
                    <td><%= esc(c.document || '-') %></td>
                    <td><%= esc(c.phone || '-') %></td>
                    <td><%= esc(c.address_display || c.address || '-') %></td>
                    <td>
                      <div class="btn-group">
                        <a
                          href="/clientes/<%= c.id %>/editar"
                          class="btn btn-secondary btn-sm btn-icon"
                          title="Editar"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </a>
                        <form
                          class="js-confirm-submit"
                          action="/clientes/<%= c.id %>/excluir"
                          method="post"
                          style="display: inline"
                          data-confirm-title="Excluir cliente?"
                          data-confirm-msg="Tem certeza que deseja excluir este cliente? Esta ação não pode ser desfeita."
                        >
                          <button type="submit" class="btn btn-danger btn-sm btn-icon" title="Excluir">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                          </button>
                        </form>
                        <%- include('../partials/whatsapp-link', { phone: c.phone }) %>
                      </div>
                    </td>
                  </tr>
                  <% }); %> <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </main>
      </div>

    </div>
    <script>
      (function () {
        var rows = document.querySelectorAll('.filterable-row');
        var filterCodigo = document.getElementById('filter-codigo');
        var filterNome = document.getElementById('filter-nome');
        var filterCpf = document.getElementById('filter-cpf');
        var filterCelular = document.getElementById('filter-celular');
        var filterEndereco = document.getElementById('filter-endereco');
        var filterClear = document.getElementById('filter-clear');
        var filterNoMatch = document.getElementById('clientes-filter-no-match');
        var tbody = document.querySelector('.table-clientes tbody');
        var sortCol = 'codigo';
        var sortDir = 'desc';

        function getDataRows() {
          return Array.prototype.filter.call(rows, function (tr) {
            return !tr.querySelector('.table-empty');
          });
        }

        function updateSortIndicators() {
          document.querySelectorAll('.th-sort').forEach(function (btn) {
            var col = btn.dataset.sortCol;
            var dirEl = btn.querySelector('.th-sort-dir');
            var active = sortCol === col;
            btn.classList.toggle('th-sort--active', active);
            if (dirEl) {
              dirEl.textContent = active ? (sortDir === 'asc' ? '↑' : '↓') : '';
            }
            btn.setAttribute('aria-sort', active ? (sortDir === 'asc' ? 'ascending' : 'descending') : 'none');
          });
        }

        function sortRows() {
          if (!tbody) return;
          var key = sortCol + '-' + sortDir;
          var dataRows = getDataRows();
          if (dataRows.length < 2) return;

          function num(a, k) {
            var n = parseInt(a.dataset[k], 10);
            return isNaN(n) ? -1 : n;
          }
          function rowId(a) {
            return parseInt(a.dataset.rowId, 10) || 0;
          }
          function cmp(a, b, field) {
            var va = (a.dataset[field] || '').toString();
            var vb = (b.dataset[field] || '').toString();
            return va.localeCompare(vb, 'pt-BR', { sensitivity: 'base' });
          }

          dataRows.sort(function (a, b) {
            var n, c;
            switch (key) {
              case 'codigo-desc':
                n = num(a, 'sortCodigoNum') - num(b, 'sortCodigoNum');
                if (n !== 0) return -n;
                return rowId(b) - rowId(a);
              case 'codigo-asc':
                n = num(a, 'sortCodigoNum') - num(b, 'sortCodigoNum');
                if (n !== 0) return n;
                return rowId(a) - rowId(b);
              case 'nome-asc':
                c = cmp(a, b, 'nome');
                return c !== 0 ? c : rowId(a) - rowId(b);
              case 'nome-desc':
                c = cmp(a, b, 'nome');
                return c !== 0 ? -c : rowId(b) - rowId(a);
              case 'cpf-asc':
                c = cmp(a, b, 'cpf');
                return c !== 0 ? c : rowId(a) - rowId(b);
              case 'cpf-desc':
                c = cmp(a, b, 'cpf');
                return c !== 0 ? -c : rowId(b) - rowId(a);
              case 'celular-asc':
                c = cmp(a, b, 'celular');
                return c !== 0 ? c : rowId(a) - rowId(b);
              case 'celular-desc':
                c = cmp(a, b, 'celular');
                return c !== 0 ? -c : rowId(b) - rowId(a);
              case 'endereco-asc':
                c = cmp(a, b, 'endereco');
                return c !== 0 ? c : rowId(a) - rowId(b);
              case 'endereco-desc':
                c = cmp(a, b, 'endereco');
                return c !== 0 ? -c : rowId(b) - rowId(a);
              default:
                return 0;
            }
          });

          dataRows.forEach(function (tr) {
            tbody.appendChild(tr);
          });
          applyFilters();
        }

        function applyFilters() {
          var codigo = (filterCodigo && filterCodigo.value || '').trim().toLowerCase();
          var nome = (filterNome && filterNome.value || '').trim().toLowerCase();
          var cpf = (filterCpf && filterCpf.value || '').trim().toLowerCase();
          var celular = (filterCelular && filterCelular.value || '').trim().toLowerCase();
          var endereco = (filterEndereco && filterEndereco.value || '').trim().toLowerCase();

          var dataVisible = 0;
          var dataTotal = 0;
          rows.forEach(function (tr) {
            if (tr.querySelector('.table-empty')) {
              tr.style.display = '';
              return;
            }
            dataTotal += 1;
            var matchCodigo = !codigo || (tr.dataset.codigo && tr.dataset.codigo.indexOf(codigo) !== -1);
            var matchNome = !nome || (tr.dataset.nome && tr.dataset.nome.indexOf(nome) !== -1);
            var matchCpf = !cpf || (tr.dataset.cpf && tr.dataset.cpf.indexOf(cpf) !== -1);
            var matchCelular = !celular || (tr.dataset.celular && tr.dataset.celular.indexOf(celular) !== -1);
            var matchEndereco = !endereco || (tr.dataset.endereco && tr.dataset.endereco.indexOf(endereco) !== -1);
            var show = matchCodigo && matchNome && matchCpf && matchCelular && matchEndereco;
            tr.style.display = show ? '' : 'none';
            if (show) dataVisible += 1;
          });
          if (filterNoMatch) {
            filterNoMatch.hidden = !(dataTotal > 0 && dataVisible === 0);
          }
        }

        function clearFilters() {
          if (filterCodigo) filterCodigo.value = '';
          if (filterNome) filterNome.value = '';
          if (filterCpf) filterCpf.value = '';
          if (filterCelular) filterCelular.value = '';
          if (filterEndereco) filterEndereco.value = '';
          applyFilters();
        }

        [filterCodigo, filterNome, filterCpf, filterCelular, filterEndereco].forEach(function (el) {
          if (el) el.addEventListener('input', applyFilters);
        });
        if (filterClear) filterClear.addEventListener('click', clearFilters);

        document.querySelectorAll('.th-sort').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var col = btn.dataset.sortCol;
            if (!col) return;
            if (sortCol === col) {
              sortDir = sortDir === 'asc' ? 'desc' : 'asc';
            } else {
              sortCol = col;
              sortDir = col === 'codigo' ? 'desc' : 'asc';
            }
            updateSortIndicators();
            sortRows();
          });
        });
        updateSortIndicators();
      })();
    </script>
  </body>
</html>
