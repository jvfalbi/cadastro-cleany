<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title><%= (customer && customer.id) ? 'Editar cliente' : 'Novo cliente' %> - Cleany</title>
    <%- include('../partials/head-viewport') %>
    <%- include('../partials/head-styles') %>
  </head>
  <body>
    <div class="app-shell">
      <div class="layout layout--nav-drawer">
        <%- include('../partials/navbar') %>
        <main class="main-content">
          <div class="container">
            <div class="page-header">
              <div>
                <div class="page-title">
                  <%= (customer && customer.id) ? 'Editar cliente' : 'Novo cliente' %>
                </div>
                <div class="page-subtitle">
                  Dados básicos para contato e emissão de O.S.
                </div>
              </div>
            </div>

            <div class="card">
              <% if (typeof error !== 'undefined' && error) { %>
              <div class="form-error" role="alert">
                <%= error %>
              </div>
              <% } %>
              <form
                action="<%= (customer && customer.id) ? '/clientes/' + customer.id : '/clientes' %>"
                method="post"
              >
                <div class="form-grid">
                  <% if (customer && customer.id) { %>
                  <div class="form-group">
                    <label for="codigo">Código</label>
                    <input
                      type="text"
                      id="codigo"
                      name="codigo"
                      value="<%= customer.codigo ? customer.codigo : '' %>"
                      placeholder="Código da planilha"
                    />
                  </div>
                  <% } else { %>
                  <p class="hint" style="grid-column: 1 / -1; margin: 0 0 0.25rem 0">
                    O <strong>código</strong> do cliente será gerado automaticamente na sequência dos cadastros ao salvar.
                  </p>
                  <% } %>
                  <div class="form-group">
                    <label for="name">Nome*</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      value="<%= customer ? customer.name : '' %>"
                    />
                  </div>
                  <div class="form-group">
                    <label for="nome_fantasia">Nome fantasia</label>
                    <input
                      type="text"
                      id="nome_fantasia"
                      name="nome_fantasia"
                      value="<%= customer && customer.nome_fantasia ? customer.nome_fantasia : '' %>"
                      placeholder="Opcional"
                    />
                  </div>

                  <div class="form-group">
                    <label for="phone">Telefone / WhatsApp*</label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      required
                      value="<%= customer ? customer.phone : '' %>"
                    />
                    <% if (customer && customer.phone) { %><%- include('../partials/whatsapp-link', { phone: customer.phone }) %><% } %>
                  </div>

                  <div class="form-group">
                    <label for="email">E-mail</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      value="<%= customer ? customer.email : '' %>"
                    />
                  </div>

                  <div class="form-group">
                    <label for="document">CPF/CNPJ*</label>
                    <input
                      type="text"
                      id="document"
                      name="document"
                      required
                      value="<%= customer ? customer.document : '' %>"
                    />
                  </div>

                  <div class="form-group" style="grid-column: 1 / -1">
                    <label for="address">Endereço completo</label>
                    <input
                      type="text"
                      id="address"
                      name="address"
                      value="<%= customer ? customer.address : '' %>"
                    />
                  </div>

                  <div class="form-group" style="grid-column: 1 / -1">
                    <label for="notes">Observações</label>
                    <textarea id="notes" name="notes">
<%= customer && customer.notes ? customer.notes : '' %></textarea
                    >
                  </div>
                </div>

                <div class="form-actions">
                  <div class="btn-group">
                    <button type="submit" class="btn btn-primary">
                      <%= (customer && customer.id) ? 'Salvar alterações' : 'Salvar cliente' %>
                    </button>
                    <a href="/clientes" class="btn btn-secondary"
                      >Voltar para lista</a
                    >
                  </div>
                  <div class="hint">Campos marcados com * são obrigatórios.</div>
                </div>
              </form>
            </div>
          </div>
        </main>
      </div>

    </div>
  </body>
</html>

