<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Histórico de agendamentos - Cleany</title>
    <%- include('partials/head-viewport') %>
    <%- include('partials/head-styles') %>
  </head>
  <body>
    <div class="app-shell">
      <div class="layout layout--nav-drawer">
        <%- include('partials/navbar') %>
        <main class="main-content">
          <div class="container">
            <div class="page-header">
              <div>
                <div class="page-title">Histórico de agendamentos</div>
              </div>
              <a href="/ordens/nova" class="btn btn-primary">+ Nova O.S.</a>
            </div>

            <% if (typeof stats !== 'undefined' && stats) { %>
            <div class="stats-row">
              <div class="stat-card stat-total">
                <div class="stat-value"><%= stats.total %></div>
                <div class="stat-label">Total</div>
              </div>
              <div class="stat-card stat-open">
                <div class="stat-value"><%= stats.Aberta || 0 %></div>
                <div class="stat-label">Abertas</div>
              </div>
              <div class="stat-card stat-progress">
                <div class="stat-value"><%= stats['Em andamento'] || 0 %></div>
                <div class="stat-label">Em andamento</div>
              </div>
              <div class="stat-card stat-done">
                <div class="stat-value"><%= stats.Concluída || 0 %></div>
                <div class="stat-label">Concluídas</div>
              </div>
              <div class="stat-card stat-cancelled">
                <div class="stat-value"><%= stats.Cancelada || 0 %></div>
                <div class="stat-label">Canceladas</div>
              </div>
            </div>
            <% } %>

            <% function esc(v) { return (v||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); } %>
            <% var servicosUnicos = []; var seenServ = {}; if (orders && orders.length) { orders.forEach(function(o) { var d = (o.description || '').trim(); if (d && !seenServ[d]) { seenServ[d] = true; servicosUnicos.push(d); } }); servicosUnicos.sort(function(a,b) { return a.localeCompare(b, 'pt-BR'); }); } %>
            <div class="card">
              <table class="table-historico-agenda">
                <thead>
                  <tr class="filter-row">
                    <th>
                      <span class="th-label">#</span>
                      <input type="text" id="filter-id" class="filter-search" placeholder="Pesquisar..." title="Número da O.S." />
                    </th>
                    <th>
                      <span class="th-label">Cliente</span>
                      <input type="text" id="filter-cliente" class="filter-search" placeholder="Pesquisar..." />
                    </th>
                    <th>
                      <span class="th-label">Data prevista</span>
                      <input
                        type="date"
                        id="filter-prevista"
                        class="filter-date-input filter-date-input--solo"
                        title="Escolha uma data no calendário para filtrar"
                        aria-label="Filtrar por data prevista"
                      />
                    </th>
                    <th>
                      <span class="th-label">Horário</span>
                      <input type="text" id="filter-hora" class="filter-search" placeholder="Pesquisar..." />
                    </th>
                    <th>
                      <span class="th-label">Serviço</span>
                      <select id="filter-servico" class="filter-select" title="Filtrar por serviço" aria-label="Filtrar por serviço">
                        <option value="">Todos</option>
                        <% servicosUnicos.forEach(function(s) { %>
                        <option value="<%= esc(s.toLowerCase()) %>"><%= esc(s.length > 80 ? s.substring(0, 80) + '…' : s) %></option>
                        <% }); %>
                      </select>
                    </th>
                    <th>
                      <span class="th-label">Status</span>
                      <select id="filter-status" class="filter-select" title="Filtrar por status" aria-label="Filtrar por status">
                        <option value="">Todos</option>
                        <option value="aberta">Aberta</option>
                        <option value="em andamento">Em andamento</option>
                        <option value="concluída">Concluída</option>
                        <option value="cancelada">Cancelada</option>
                      </select>
                    </th>
                    <th class="filter-actions">
                      <span class="th-label">Ações</span>
                      <button type="button" class="btn btn-secondary btn-sm" id="filter-clear" title="Limpar filtros">Limpar</button>
                    </th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!orders || orders.length === 0) { %>
                  <tr class="filterable-row">
                    <td colspan="7" class="table-empty">
                      Nenhum agendamento cadastrado ainda.
                    </td>
                  </tr>
                  <% } else { %> <% orders.forEach(function (o) {
                    var dataPrev = '';
                    if (o.due_date) {
                      try { dataPrev = new Date(o.due_date + 'T12:00:00').toLocaleDateString('pt-BR'); } catch (e) { dataPrev = o.due_date; }
                    }
                    var horaPrev = (o.due_time || '').slice(0, 5) || '—';
                    if (!o.due_date) { dataPrev = '—'; }
                    var previstaIso = '';
                    if (o.due_date) {
                      previstaIso = String(o.due_date).trim().slice(0, 10);
                    }
                  %>
                  <tr
                    class="filterable-row"
                    data-id="<%= String(o.id) %>"
                    data-cliente="<%= esc((o.customer_name || '').toLowerCase()) %>"
                    data-data="<%= esc((dataPrev !== '—' ? dataPrev : '').toLowerCase()) %>"
                    data-hora="<%= esc(String(horaPrev).toLowerCase()) %>"
                    data-servico="<%= esc((o.description || '').toLowerCase()) %>"
                    data-status="<%= esc((o.status || '').toLowerCase()) %>"
                    data-prevista-iso="<%= esc(previstaIso) %>"
                  >
                    <td>#<%= o.id %></td>
                    <td><%= esc(o.customer_name || '') %></td>
                    <td><%= dataPrev %></td>
                    <td><%= horaPrev %></td>
                    <td>
                      <%=
                        (o.description || '').length > 42
                          ? esc(o.description.substring(0, 42) + '…')
                          : esc(o.description || '')
                      %>
                    </td>
                    <td>
                      <% if (o.status === 'Aberta') { %>
                      <span class="badge badge-open">Aberta</span>
                      <% } else if (o.status === 'Em andamento') { %>
                      <span class="badge badge-progress">Em andamento</span>
                      <% } else if (o.status === 'Concluída') { %>
                      <span class="badge badge-done">Concluída</span>
                      <% } else if (o.status === 'Cancelada') { %>
                      <span class="badge badge-cancelled">Cancelada</span>
                      <% } else { %>
                      <span class="badge"><%= esc(o.status || '') %></span>
                      <% } %>
                    </td>
                    <td>
                      <div class="btn-group">
                        <a href="/ordens/<%= o.id %>" class="btn btn-secondary btn-sm">Detalhes</a>
                        <%- include('partials/whatsapp-link', { phone: o.customer_phone }) %>
                      </div>
                    </td>
                  </tr>
                  <% }); %> <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </main>
      </div>
    </div>
    <script>
      (function () {
        var rows = document.querySelectorAll('.filterable-row');
        var filterId = document.getElementById('filter-id');
        var filterCliente = document.getElementById('filter-cliente');
        var filterHora = document.getElementById('filter-hora');
        var filterServico = document.getElementById('filter-servico');
        var filterStatus = document.getElementById('filter-status');
        var filterPrevista = document.getElementById('filter-prevista');
        var filterClear = document.getElementById('filter-clear');

        function matchPrevistaDate(iso) {
          var picked = filterPrevista && filterPrevista.value || '';
          if (!picked) return true;
          return iso === picked;
        }

        function applyFilters() {
          var id = (filterId && filterId.value || '').trim().toLowerCase();
          var cliente = (filterCliente && filterCliente.value || '').trim().toLowerCase();
          var hora = (filterHora && filterHora.value || '').trim().toLowerCase();
          var servico = (filterServico && filterServico.value || '').trim().toLowerCase();
          var status = (filterStatus && filterStatus.value || '').trim().toLowerCase();

          rows.forEach(function (tr) {
            if (tr.querySelector('.table-empty')) {
              tr.style.display = '';
              return;
            }
            var iso = tr.dataset.previstaIso || '';
            var matchId = !id || (tr.dataset.id && tr.dataset.id.indexOf(id) !== -1);
            var matchCliente = !cliente || (tr.dataset.cliente && tr.dataset.cliente.indexOf(cliente) !== -1);
            var matchPeriodo = matchPrevistaDate(iso);
            var matchHora = !hora || (tr.dataset.hora && tr.dataset.hora.indexOf(hora) !== -1);
            var matchServico = !servico || (tr.dataset.servico && tr.dataset.servico === servico);
            var matchStatus = !status || (tr.dataset.status && tr.dataset.status === status);
            tr.style.display =
              matchId && matchCliente && matchPeriodo && matchHora && matchServico && matchStatus ? '' : 'none';
          });
        }

        function clearFilters() {
          [filterId, filterCliente, filterHora, filterServico, filterStatus].forEach(function (el) {
            if (el) el.value = '';
          });
          if (filterPrevista) filterPrevista.value = '';
          applyFilters();
        }

        [filterId, filterCliente, filterHora].forEach(function (el) {
          if (el) el.addEventListener('input', applyFilters);
        });
        if (filterServico) filterServico.addEventListener('change', applyFilters);
        if (filterStatus) filterStatus.addEventListener('change', applyFilters);
        if (filterPrevista) {
          filterPrevista.addEventListener('change', applyFilters);
          filterPrevista.addEventListener('input', applyFilters);
        }
        if (filterClear) filterClear.addEventListener('click', clearFilters);
      })();
    </script>
  </body>
</html>
