<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Serviços - Cleany</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <div class="app-shell">
      <div class="layout layout--nav-drawer">
        <%- include('../partials/navbar') %>
        <main class="main-content">
          <div class="container">
            <div class="page-header">
              <div>
                <div class="page-title">Serviços</div>
                <div class="page-subtitle">
                  Tabela de referência para orçamentos e ordens de serviço.
                </div>
              </div>
              <a href="/servicos/novo" class="btn btn-primary">+ Novo serviço</a>
            </div>

            <div class="card">
              <table>
                <thead>
                  <tr>
                    <th>Serviço</th>
                    <th>Descrição</th>
                    <th style="width: 140px">Valor de referência</th>
                    <th style="width: 140px">Ações</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!services || services.length === 0) { %>
                  <tr>
                    <td colspan="4" class="table-empty">
                      Nenhum serviço configurado. Clique em "Novo serviço" para começar.
                    </td>
                  </tr>
                  <% } else { %>
                  <% services.forEach(function (s) { %>
                  <tr>
                    <td><%= s.name %></td>
                    <td><%= s.description || '-' %></td>
                    <td>
                      <% if (s.price != null && s.price > 0) { %>
                      R$ <%= Number(s.price).toFixed(2).replace('.', ',') %>
                      <% } else { %>
                      Sob orçamento
                      <% } %>
                    </td>
                    <td>
                      <div class="btn-group">
                        <a href="/servicos/<%= s.id %>/editar" class="btn btn-secondary btn-sm btn-icon" title="Editar">
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </a>
                        <form class="js-confirm-submit" action="/servicos/<%= s.id %>/excluir" method="post" style="display: inline" data-confirm-title="Excluir serviço?" data-confirm-msg="Tem certeza que deseja excluir este serviço? Esta ação não pode ser desfeita.">
                          <button type="submit" class="btn btn-danger btn-sm btn-icon" title="Excluir">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                  <% }); %>
                  <% } %>
                </tbody>
              </table>
              <p class="hint" style="margin-top: 0.8rem">
                Os valores acima são apenas referência. Ajuste o valor final da O.S. conforme a necessidade de cada cliente.
              </p>
            </div>
          </div>
        </main>
      </div>

    </div>
  </body>
</html>
