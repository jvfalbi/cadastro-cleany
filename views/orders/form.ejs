<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Nova ordem de serviço - Cleany</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/styles.css" />
    <style>
      .print-logo { display: none; }
      .print-only-time { display: none; }
      @media print {
        .print-logo { display: block !important; text-align: center; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid #333; }
        .print-logo img { max-height: 56px; width: auto; }
        .time-row { display: none !important; }
        .print-only-time { display: block !important; margin-bottom: 0.75rem; }
        .sidebar, .footer, .no-print { display: none !important; }
        .layout { display: block; }
        .main-content { padding: 0; }
        .container { max-width: 100%; }
        .card { box-shadow: none; border: 1px solid #333; }
        body { background: #fff; }
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <div class="layout layout--nav-drawer">
        <%- include('../partials/navbar') %>
        <main class="main-content">
          <div class="container">
            <div class="print-logo">
              <img src="/img/logocleany.png" alt="Cleany - Trituradores de Resíduos" />
            </div>
            <div class="page-header">
              <div>
                <div class="page-title">Nova ordem de serviço</div>
                <div class="page-subtitle">
                  Vincule a O.S. a um cliente e descreva o serviço.
                </div>
              </div>
              <div class="btn-group no-print">
                <a href="/ordens" class="btn btn-secondary">Voltar ao histórico</a>
                <button type="button" class="btn btn-primary" onclick="imprimirOS();">Imprimir O.S.</button>
              </div>
            </div>

            <div class="card">
              <form id="order-form" action="/ordens" method="post">
                <div class="form-grid">
                  <div class="form-group customer-picker">
                    <label for="customer_search">Cliente*</label>
                    <div class="customer-picker-inner">
                      <input type="hidden" name="customer_id" id="customer_id" value="" />
                      <input
                        type="text"
                        id="customer_search"
                        autocomplete="off"
                        placeholder="Digite nome ou código para buscar..."
                        aria-autocomplete="list"
                        aria-controls="customer_results"
                        aria-expanded="false"
                      />
                      <div id="customer_results" class="customer-search-results" role="listbox" hidden></div>
                    </div>
                    <p class="hint" id="customer_picker_hint">Digite para filtrar; clique no cliente para selecionar.</p>
                  </div>

                  <div class="form-group">
                    <label for="status">Status inicial</label>
                    <select id="status" name="status">
                      <option value="Aberta" selected>Aberta</option>
                      <option value="Em andamento">Em andamento</option>
                      <option value="Concluída">Concluída</option>
                      <option value="Cancelada">Cancelada</option>
                    </select>
                  </div>

                  <div class="form-group">
                    <label for="price_estimate">Valor estimado (R$)*</label>
                    <input
                      type="number"
                      step="0.01"
                      min="0"
                      id="price_estimate"
                      name="price_estimate"
                      required
                    />
                  </div>

                  <div class="form-group">
                    <label for="due_date">Data prevista*</label>
                    <input type="date" id="due_date" name="due_date" value="<%= prefillDate || '' %>" required />
                  </div>

                  <div class="form-group form-group--time" style="grid-column: 1 / -1;">
                    <label>Horário previsto*</label>
                    <input type="hidden" id="due_time" name="due_time" value="" required />
                    <div class="print-only-time"><strong>Horário previsto:</strong> <span id="print_time_display">—</span></div>
                    <div class="time-row">
                      <div class="time-slots-container">
                        <div id="due_time_slots" class="time-slots"></div>
                      </div>
                      <div class="time-manual-wrap">
                        <span class="time-manual-label">Encaixe</span>
                        <input type="text" id="due_time_manual" class="time-manual-input" placeholder="Ex: 08:30" maxlength="5" />
                      </div>
                    </div>
                  </div>

                  <div class="form-group" style="grid-column: 1 / -1">
                    <label for="description">Descrição do serviço*</label>
                    <textarea
                      id="description"
                      name="description"
                      required
                    ></textarea>
                  </div>
                </div>

                <div class="form-actions no-print">
                  <div class="btn-group">
                    <button type="submit" class="btn btn-primary">
                      Salvar O.S.
                    </button>
                    <a href="/ordens" class="btn btn-secondary"
                      >Voltar para lista</a
                    >
                  </div>
                  <div class="hint">Campos marcados com * são obrigatórios.</div>
                </div>
              </form>
            </div>
          </div>
        </main>
      </div>

    </div>
    <script>
      function syncPrintHorario() {
        var hid = document.getElementById('due_time');
        var printDisplay = document.getElementById('print_time_display');
        if (printDisplay && hid) {
          var v = (hid.value || '').trim();
          printDisplay.textContent = v || '—';
        }
      }
      function imprimirOS() {
        var form = document.getElementById('order-form');
        if (!form) return;
        var hid = document.getElementById('customer_id');
        var searchInput = document.getElementById('customer_search');
        if (hid && !hid.value && searchInput) {
          searchInput.setCustomValidity('Selecione um cliente na lista ao digitar.');
          searchInput.reportValidity();
          return;
        }
        if (searchInput) searchInput.setCustomValidity('');
        syncPrintHorario();
        if (form.checkValidity()) {
          window.print();
        } else {
          form.reportValidity();
        }
      }
      window.addEventListener('beforeprint', syncPrintHorario);
      (function () {
        var CUSTOMERS = <%- JSON.stringify((customers || []).map(function (c) {
          return { id: c.id, name: c.name || '', codigo: (c.codigo || '').toString().trim() };
        })) %>;

        function norm(s) {
          return (s || '')
            .toString()
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '');
        }

        var hid = document.getElementById('customer_id');
        var searchInput = document.getElementById('customer_search');
        var resultsEl = document.getElementById('customer_results');

        function showResults(show) {
          if (!resultsEl) return;
          resultsEl.hidden = !show;
          if (searchInput) searchInput.setAttribute('aria-expanded', show ? 'true' : 'false');
        }

        function renderResults(q) {
          if (!resultsEl) return;
          var nq = norm(q);
          var list = CUSTOMERS.filter(function (c) {
            if (!nq) return false;
            return norm(c.name).indexOf(nq) !== -1 || norm(c.codigo).indexOf(nq) !== -1 || String(c.id) === q.trim();
          });
          if (list.length > 80) list = list.slice(0, 80);
          resultsEl.innerHTML = '';
          if (list.length === 0) {
            var empty = document.createElement('div');
            empty.className = 'customer-search-empty';
            empty.textContent = nq
              ? 'Nenhum cliente encontrado. Tente outro termo.'
              : 'Digite pelo menos uma letra ou número para buscar.';
            resultsEl.appendChild(empty);
            showResults(true);
            return;
          }
          list.forEach(function (c) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'customer-search-item';
            btn.setAttribute('role', 'option');
            btn.dataset.id = String(c.id);
            var line1 = document.createElement('span');
            line1.textContent = c.name || '(sem nome)';
            btn.appendChild(line1);
            if (c.codigo) {
              var meta = document.createElement('span');
              meta.className = 'customer-search-meta';
              meta.textContent = 'Código: ' + c.codigo;
              btn.appendChild(meta);
            }
            btn.addEventListener('mousedown', function (e) {
              e.preventDefault();
            });
            btn.addEventListener('click', function () {
              hid.value = c.id;
              searchInput.value = c.name;
              searchInput.setCustomValidity('');
              showResults(false);
            });
            resultsEl.appendChild(btn);
          });
          showResults(true);
        }

        if (searchInput && hid) {
          searchInput.addEventListener('input', function () {
            hid.value = '';
            renderResults(this.value);
          });
          searchInput.addEventListener('focus', function () {
            if (norm(this.value)) renderResults(this.value);
          });
          searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
              showResults(false);
            }
          });
          document.addEventListener('click', function (e) {
            if (!resultsEl || resultsEl.hidden) return;
            var wrap = document.querySelector('.customer-picker-inner');
            if (wrap && !wrap.contains(e.target)) showResults(false);
          });
        }

        var orderForm = document.getElementById('order-form');
        if (orderForm && hid && searchInput) {
          orderForm.addEventListener('submit', function (e) {
            if (!hid.value) {
              e.preventDefault();
              searchInput.setCustomValidity('Selecione um cliente na lista ao digitar.');
              searchInput.reportValidity();
              renderResults(searchInput.value);
              return;
            }
            searchInput.setCustomValidity('');
          });
        }

        var slots = [];
        for (var h = 8; h <= 17; h++) {
          var hh = h < 10 ? '0' + h : '' + h;
          slots.push(hh + ':00');
        }
        var hiddenInput = document.getElementById('due_time');
        var container = document.getElementById('due_time_slots');
        var manualInput = document.getElementById('due_time_manual');
        var dateInput = document.getElementById('due_date');
        var initialOcupados = <%- JSON.stringify(typeof prefillOcupados !== 'undefined' ? prefillOcupados : []) %>;

        var printDisplay = document.getElementById('print_time_display');
        function atualizarPrintTime(v) {
          if (printDisplay) printDisplay.textContent = v || '—';
        }
        if (manualInput) {
          manualInput.addEventListener('input', function () {
            var raw = this.value.replace(/\D/g, '').slice(0, 4);
            var masked = raw.length <= 2 ? raw : raw.slice(0, 2) + ':' + raw.slice(2);
            this.value = masked;
            hiddenInput.value = masked;
            atualizarPrintTime(masked);
            container.querySelectorAll('.time-slot-btn').forEach(function (b) { b.classList.remove('selected'); });
          });
        }

        function horaOcupada(slot, ocupados) {
          var h = slot.slice(0, 2);
          return ocupados.indexOf(h + ':00') !== -1 || ocupados.indexOf(h + ':30') !== -1;
        }
        function preencherHorarios(ocupados) {
          container.innerHTML = '';
          hiddenInput.value = '';
          atualizarPrintTime('');
          if (manualInput) manualInput.value = '';
          for (var i = 0; i < slots.length; i++) {
            if (horaOcupada(slots[i], ocupados)) continue;
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'time-slot-btn';
            btn.textContent = slots[i];
            btn.dataset.time = slots[i];
            btn.addEventListener('click', function () {
              var t = this.dataset.time;
              container.querySelectorAll('.time-slot-btn').forEach(function (b) { b.classList.remove('selected'); });
              this.classList.add('selected');
              hiddenInput.value = t;
              atualizarPrintTime(t);
              if (manualInput) manualInput.value = '';
            });
            container.appendChild(btn);
          }
        }

        preencherHorarios(initialOcupados);

        dateInput.addEventListener('change', function () {
          var data = this.value;
          if (!data) {
            preencherHorarios([]);
            return;
          }
          fetch('/api/ordens/ocupados?data=' + encodeURIComponent(data))
            .then(function (r) { return r.json(); })
            .then(function (d) { preencherHorarios(d.ocupados || []); })
            .catch(function () { preencherHorarios([]); });
        });
        atualizarPrintTime(hiddenInput.value);
      })();
    </script>
  </body>
</html>

