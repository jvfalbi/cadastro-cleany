<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <title>Gerar O.S. - Cleany</title>
    <%- include('../partials/head-viewport') %>
    <%- include('../partials/head-styles') %>
    <style>
      .os-period-card { margin-bottom: 1.25rem; }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <div class="layout layout--nav-drawer">
        <%- include('../partials/navbar') %>
        <main class="main-content">
          <div class="container">
            <div class="page-header">
              <div>
                <div class="page-title">Gerar O.S.</div>
                <div class="page-subtitle">
                  Histórico e analítico geral das ordens de serviço.
                </div>
              </div>
              <a href="/ordens/nova" class="btn btn-primary">Gerar nova O.S.</a>
            </div>

            <% if (typeof stats !== 'undefined' && stats) { %>
            <div class="stats-row">
              <div class="stat-card stat-total">
                <div class="stat-value"><%= stats.total %></div>
                <div class="stat-label">Total</div>
              </div>
              <div class="stat-card stat-open">
                <div class="stat-value"><%= stats.Aberta || 0 %></div>
                <div class="stat-label">Abertas</div>
              </div>
              <div class="stat-card stat-progress">
                <div class="stat-value"><%= stats['Em andamento'] || 0 %></div>
                <div class="stat-label">Em andamento</div>
              </div>
              <div class="stat-card stat-done">
                <div class="stat-value"><%= stats.Concluída || 0 %></div>
                <div class="stat-label">Concluídas</div>
              </div>
              <div class="stat-card stat-cancelled">
                <div class="stat-value"><%= stats.Cancelada || 0 %></div>
                <div class="stat-label">Canceladas</div>
              </div>
            </div>
            <% } %>

            <% function esc(v) { return (v||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;'); } %>
            <% var servicosUnicos = []; var seenServ = {}; if (orders && orders.length) { orders.forEach(function(o) { var d = (o.description || '').trim(); if (d && !seenServ[d]) { seenServ[d] = true; servicosUnicos.push(d); } }); servicosUnicos.sort(function(a,b) { return a.localeCompare(b, 'pt-BR'); }); } %>
            <% var now = new Date(); var m1 = new Date(now.getFullYear(), now.getMonth(), 1); var m2 = new Date(now.getFullYear(), now.getMonth() + 1, 0); var m3 = new Date(now.getFullYear(), now.getMonth() - 1, 1); var m4 = new Date(now.getFullYear(), now.getMonth(), 0); var y1 = new Date(now.getFullYear(), 0, 1); var y2 = new Date(now.getFullYear(), 11, 31); %>
            <div class="card os-period-card">
              <h2>Filtrar por período (data de abertura)</h2>
              <form class="finance-filter" id="os-period-form" action="#" onsubmit="return false;">
                <div class="form-group">
                  <label for="filter-de">Data início</label>
                  <input type="date" id="filter-de" name="de" />
                </div>
                <div class="form-group">
                  <label for="filter-ate">Data fim</label>
                  <input type="date" id="filter-ate" name="ate" />
                </div>
                <button type="button" class="btn btn-primary" id="filter-apply-dates">Filtrar</button>
                <div class="finance-quick">
                  <span style="font-size: 0.85rem; color: var(--text-muted);">Atalhos:</span>
                  <button type="button" class="btn btn-secondary btn-sm js-os-period-quick" data-de="<%= m1.toISOString().slice(0,10) %>" data-ate="<%= m2.toISOString().slice(0,10) %>">Este mês</button>
                  <button type="button" class="btn btn-secondary btn-sm js-os-period-quick" data-de="<%= m3.toISOString().slice(0,10) %>" data-ate="<%= m4.toISOString().slice(0,10) %>">Mês passado</button>
                  <button type="button" class="btn btn-secondary btn-sm js-os-period-quick" data-de="<%= y1.toISOString().slice(0,10) %>" data-ate="<%= y2.toISOString().slice(0,10) %>">Este ano</button>
                </div>
              </form>
            </div>

            <div class="card">
              <table>
                <thead>
                  <tr class="filter-row">
                    <th>
                      <span class="th-label">#</span>
                      <input type="text" id="filter-id" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por número" />
                    </th>
                    <th>
                      <span class="th-label">Cliente</span>
                      <input type="text" id="filter-cliente" class="filter-search" placeholder="Pesquisar..." title="Pesquisar por cliente" />
                    </th>
                    <th>
                      <span class="th-label">Serviço</span>
                      <select id="filter-servico" class="filter-select" title="Filtrar por serviço" aria-label="Filtrar por serviço">
                        <option value="">Todos</option>
                        <% servicosUnicos.forEach(function(s) { %>
                        <option value="<%= esc(s.toLowerCase()) %>"><%= esc(s.length > 80 ? s.substring(0, 80) + '…' : s) %></option>
                        <% }); %>
                      </select>
                    </th>
                    <th>
                      <span class="th-label">Status</span>
                      <select id="filter-status" class="filter-select" title="Filtrar por status" aria-label="Filtrar por status">
                        <option value="">Todos</option>
                        <option value="aberta">Aberta</option>
                        <option value="em andamento">Em andamento</option>
                        <option value="concluída">Concluída</option>
                        <option value="cancelada">Cancelada</option>
                      </select>
                    </th>
                    <th>
                      <span class="th-label">Data de abertura</span>
                    </th>
                    <th class="filter-actions">
                      <span class="th-label">Ações</span>
                      <button type="button" class="btn btn-secondary btn-sm" id="filter-clear" title="Limpar filtros">Limpar</button>
                    </th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!orders || orders.length === 0) { %>
                  <tr class="filterable-row">
                    <td colspan="6" class="table-empty">
                      Nenhuma ordem de serviço cadastrada ainda.
                    </td>
                  </tr>
                  <% } else { %> <% orders.forEach(function (o) {
                    var dataAbertura = new Date(o.created_at).toLocaleDateString('pt-BR');
                    var aberturaIso = '';
                    if (o.created_at) {
                      var da = new Date(o.created_at);
                      aberturaIso = da.getFullYear() + '-' + String(da.getMonth() + 1).padStart(2, '0') + '-' + String(da.getDate()).padStart(2, '0');
                    }
                  %>
                  <tr class="filterable-row" data-id="<%= String(o.id) %>" data-cliente="<%= esc((o.customer_name || '').toLowerCase()) %>" data-servico="<%= esc((o.description || '').toLowerCase()) %>" data-status="<%= esc((o.status || '').toLowerCase()) %>" data-data="<%= esc(dataAbertura.toLowerCase()) %>" data-abertura-iso="<%= esc(aberturaIso) %>">
                    <td>#<%= o.id %></td>
                    <td><%= o.customer_name %></td>
                    <td>
                      <%=
                        o.description.length > 40
                          ? o.description.substring(0, 40) + '...'
                          : o.description
                      %>
                    </td>
                    <td>
                      <% if (o.status === 'Aberta') { %>
                      <span class="badge badge-open">Aberta</span>
                      <% } else if (o.status === 'Em andamento') { %>
                      <span class="badge badge-progress">Em andamento</span>
                      <% } else if (o.status === 'Concluída') { %>
                      <span class="badge badge-done">Concluída</span>
                      <% } else if (o.status === 'Cancelada') { %>
                      <span class="badge badge-cancelled">Cancelada</span>
                      <% } else { %>
                      <span class="badge"><%= o.status %></span>
                      <% } %>
                    </td>
                    <td><%= dataAbertura %></td>
                    <td>
                      <div class="btn-group">
                        <a href="/ordens/<%= o.id %>" class="btn btn-secondary btn-sm">Detalhes</a>
                        <%- include('../partials/whatsapp-link', { phone: o.customer_phone }) %>
                      </div>
                    </td>
                  </tr>
                  <% }); %> <% } %>
                </tbody>
              </table>
            </div>
          </div>
        </main>
      </div>

    </div>
    <script>
      (function () {
        var rows = document.querySelectorAll('.filterable-row');
        var filterId = document.getElementById('filter-id');
        var filterCliente = document.getElementById('filter-cliente');
        var filterServico = document.getElementById('filter-servico');
        var filterStatus = document.getElementById('filter-status');
        var filterDe = document.getElementById('filter-de');
        var filterAte = document.getElementById('filter-ate');
        var filterApplyDates = document.getElementById('filter-apply-dates');
        var filterClear = document.getElementById('filter-clear');

        function matchDateRange(iso) {
          var de = filterDe && filterDe.value || '';
          var ate = filterAte && filterAte.value || '';
          if (!de && !ate) return true;
          if (!iso) return false;
          if (de && iso < de) return false;
          if (ate && iso > ate) return false;
          return true;
        }

        function applyFilters() {
          var id = (filterId && filterId.value || '').trim().toLowerCase();
          var cliente = (filterCliente && filterCliente.value || '').trim().toLowerCase();
          var servico = (filterServico && filterServico.value || '').trim().toLowerCase();
          var status = (filterStatus && filterStatus.value || '').trim().toLowerCase();

          rows.forEach(function (tr) {
            if (tr.querySelector('.table-empty')) {
              tr.style.display = '';
              return;
            }
            var iso = tr.dataset.aberturaIso || '';
            var matchId = !id || (tr.dataset.id && tr.dataset.id.indexOf(id) !== -1);
            var matchCliente = !cliente || (tr.dataset.cliente && tr.dataset.cliente.indexOf(cliente) !== -1);
            var matchServico = !servico || (tr.dataset.servico && tr.dataset.servico === servico);
            var matchStatus = !status || (tr.dataset.status && tr.dataset.status === status);
            var matchData = matchDateRange(iso);
            tr.style.display = (matchId && matchCliente && matchServico && matchStatus && matchData) ? '' : 'none';
          });
        }

        function clearFilters() {
          if (filterId) filterId.value = '';
          if (filterCliente) filterCliente.value = '';
          if (filterServico) filterServico.value = '';
          if (filterStatus) filterStatus.value = '';
          if (filterDe) filterDe.value = '';
          if (filterAte) filterAte.value = '';
          applyFilters();
        }

        [filterId, filterCliente].forEach(function (el) {
          if (el) el.addEventListener('input', applyFilters);
        });
        if (filterServico) filterServico.addEventListener('change', applyFilters);
        if (filterStatus) filterStatus.addEventListener('change', applyFilters);
        if (filterDe) filterDe.addEventListener('change', applyFilters);
        if (filterAte) filterAte.addEventListener('change', applyFilters);
        if (filterApplyDates) filterApplyDates.addEventListener('click', applyFilters);
        document.querySelectorAll('.js-os-period-quick').forEach(function (btn) {
          btn.addEventListener('click', function () {
            if (filterDe) filterDe.value = btn.getAttribute('data-de') || '';
            if (filterAte) filterAte.value = btn.getAttribute('data-ate') || '';
            applyFilters();
          });
        });
        if (filterClear) filterClear.addEventListener('click', clearFilters);
      })();
    </script>
  </body>
</html>

