# Copie para .env (nunca commite o arquivo .env)
# Em produção (NODE_ENV=production): LOGIN_*, SESSION_SECRET são obrigatórios; SESSION_SECRET mín. 16 caracteres.
# Em desenvolvimento sem .env: o app usa usuário/senha cleany-dev / cleany-dev

PORT=3000
SESSION_SECRET=troque_por_uma_string_bem_longa_e_unica
LOGIN_USER=seu_usuario
LOGIN_PASSWORD=sua_senha_forte
