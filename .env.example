# Copie para .env (nunca commite o arquivo .env)
# Em produção (NODE_ENV=production): LOGIN_*, SESSION_SECRET são obrigatórios; SESSION_SECRET mín. 16 caracteres.
# Em desenvolvimento sem LOGIN_* no .env: o app usa o login padrão definido em src/server.js (DEV_LOGIN_*)

PORT=3000
SESSION_SECRET=troque_por_uma_string_bem_longa_e_unica
LOGIN_USER=seu_usuario
# Não coloque # no fim da linha (tudo depois de # vira comentário). Se a senha tiver ! ou espaços, use aspas:
# LOGIN_PASSWORD='Butt1005!'
LOGIN_PASSWORD=sua_senha_forte

# Contas extras (JSON em uma linha). Somam ao LOGIN_USER acima. Na 1ª execução são copiadas para o banco (tabela app_users); depois use o menu "Usuários do sistema" no app.
# LOGIN_ACCOUNTS_JSON=[{"user":"cleany_trituradores","password":"defina_uma_senha"}]

# URL pública do site (domínio novo), sem barra no final. Ex.: https://app.suaempresa.com.br
# Usada nos templates (baseUrl / absUrl) e para cookie seguro em HTTPS. Se vazio, o app usa o Host de cada pedido.
BASE_URL=

# Opcional: force cookie de sessão só em HTTPS (1 = sim). Se não definir, ativa sozinho quando BASE_URL começa com https://
# SESSION_COOKIE_SECURE=1

# Só em desenvolvimento: força o login padrão do código mesmo se LOGIN_* existirem no .env
# LOCAL_FORCE_DEV_LOGIN=1

# Só este usuário vê /admin/usuarios (se vazio, usa o mesmo usuário padrão de dev: joaofalbi). Ex.: ADMIN_USERNAME=jvfalbi
# ADMIN_USERNAME=

# Nome do processo no PM2 (menu Manutenção → reiniciar). Padrão: cadastro-cleany
# PM2_APP_NAME=cadastro-cleany
